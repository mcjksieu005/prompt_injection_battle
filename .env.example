# (選填) 系統路徑前綴，若架在網域根目錄請留空或設為 /prompt_battle
BASE_PATH=/prompt_battle

# 👑 關主 (Admin) 登入設定
# 這裡設定你的隱蔽式帳號，例如不叫 admin，改叫 admin6767
ADMIN_USERNAME=admin6767
# 這裡設定關主的密碼
ADMIN_PWD=HereIsMySuperSecretAdminPassword

# ⚔️ 遊戲初始小隊密碼 (僅限伺服器剛啟動的第一局)
# 系統剛開啟時，紅藍隊的初始密碼。
# 備註：第二場開始，只要關主在後台按下「產生隨機密碼」，這兩行就會暫時失效，進入亂數密碼模式。
RED_PWD=red67
BLUE_PWD=blue67

# 🤖 OpenRouter API Key (你原本就有的)
OPENROUTER_API_KEY=sk-or-v1-你的API金鑰......