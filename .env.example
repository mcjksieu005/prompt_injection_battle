# ==========================================
# ⚙️ 核心系統設定
# ==========================================
# (必填) OpenRouter 的 API 金鑰
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxx

# (選填) 系統路徑前綴，若架在網域根目錄請留空；若在子目錄請加上斜線，例如 /prompt_battle
BASE_PATH=/prompt_battle

# (必填) 密碼雜湊鹽巴，請隨便打一串超長的英數字，保護密碼不被彩虹表破解
PASSWORD_SALT=CSIE_CAMP_PROMPT_BATTLE_SUPER_SECRET_SALT_999


# ==========================================
# 👑 關主 (Admin) 登入設定
# ==========================================
# 關主登入的隱蔽式帳號 (防猜測，不建議使用預設的 admin)
ADMIN_USERNAME=admin6767

# 關主登入的密碼
ADMIN_PWD=HereIsMySuperSecretAdminPassword


# ==========================================
# ⚔️ 遊戲初始小隊密碼 (僅限伺服器剛啟動的第一局)
# ==========================================
# 系統剛開啟時，紅藍隊的初始密碼。
# 備註：第二場開始，只要關主在後台按下「產生隨機密碼」，這兩行就會失效，進入亂數密碼模式。
RED_PWD=red67
BLUE_PWD=blue67